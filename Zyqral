from openai import OpenAI
import os
import subprocess

client = OpenAI(
    base_url="http://localhost:1234/v1",
    api_key="lm-studio"
)

def list_files(path):
    try:
        return os.listdir(path)
    except Exception as e:
        return str(e)

def read_file(path):
    try:
        with open(path, 'r') as f:
            return f.read()
    except Exception as e:
        return str(e)

def run_python(code):
    try:
        result = subprocess.run(['py', '-3.11', '-c', code], 
                              capture_output=True, text=True, timeout=10)
        return result.stdout or result.stderr
    except Exception as e:
        return str(e)

tools = {
    "list_files": list_files,
    "read_file": read_file,
    "run_python": run_python
}

conversation = [
    {"role": "system", "content": """You are an autonomous AI agent on a Windows 10 machine.
You have access to these tools - call them by writing TOOL: toolname(argument) on its own line:
- TOOL: list_files(C:\\path) - lists files in a directory
- TOOL: read_file(C:\\path\\file.txt) - reads a file
- TOOL: run_python(code) - runs python code

Always reason step by step before using a tool."""}
]

print("Agent ready. Type your task:")

while True:
    user_input = input("\nYou: ")
    if user_input.lower() in ["exit", "quit"]:
        break
    
    conversation.append({"role": "user", "content": user_input})
    
    response = client.chat.completions.create(
        model="qwen",
        messages=conversation
    )
    
    reply = response.choices[0].message.content
    conversation.append({"role": "assistant", "content": reply})
    print(f"\nAgent: {reply}")

    # Parse and execute tool calls
    for line in reply.split('\n'):
        if line.startswith('TOOL:'):
            try:
                call = line[5:].strip()
                tool_name = call.split('(')[0]
                arg = call.split('(')[1].rstrip(')')
                if tool_name in tools:
                    result = tools[tool_name](arg)
                    print(f"\nTool result: {result}")
                    conversation.append({"role": "user", "content": f"Tool result: {result}"})
            except Exception as e:
                print(f"Tool error: {e}")