from openai import OpenAI
import os
import subprocess

client = OpenAI(
    base_url="http://localhost:1234/v1",
    api_key="lm-studio"
)

def list_files(path):
    try:
        return os.listdir(path)
    except Exception as e:
        return str(e)

def read_file(path):
    try:
        with open(path, 'r', encoding='utf-8') as f:
            return f.read()
    except Exception as e:
        return str(e)

def run_python(code):
    try:
        result = subprocess.run(['py', '-3.11', '-c', code],
                              capture_output=True, text=True, timeout=30)
        return result.stdout or result.stderr
    except Exception as e:
        return str(e)

def write_file(args):
    try:
        parts = args.split('|', 1)
        if len(parts) != 2:
            return "write_file requires path|content format"
        path, content = parts[0].strip(), parts[1].strip()
        if not path.startswith("C:\\AI\\workspace"):
            return "BLOCKED: can only write inside C:\\AI\\workspace"
        os.makedirs(os.path.dirname(path), exist_ok=True)
        with open(path, 'w', encoding='utf-8') as f:
            f.write(content)
        return f"Written successfully to {path}"
    except Exception as e:
        return str(e)

tools = {
    "list_files": list_files,
    "read_file": read_file,
    "run_python": run_python,
    "write_file": write_file
}

conversation = [
    {"role": "system", "content": """You are an autonomous AI agent running on a Windows 10 machine.

You have access to these tools - call them by writing the prefix on its own line:
- TOOL: list_files(C:\\path) - lists files in a directory
- TOOL: read_file(C:\\path\\file.txt) - reads a file
- TOOL: run_python(code) - runs python code
- TOOL: write_file(C:\\AI\\workspace\\file.txt|content) - writes a file (workspace only)

Before every action follow this format:
THINK: your step by step reasoning about what to do and why
TOOL: toolname(argument)
RESULT: what you concluded from the tool output

Rules:
- Always reason before acting
- You may call multiple tools in sequence to complete a task
- Never delete or modify files outside C:\\AI\\workspace
- When writing files always write COMPLETE content in full, never truncate or summarize
- The write_file tool uses path|content format with the ENTIRE content after the pipe
- If a task requires multiple steps, work through them one at a time
- When you have finished all steps, summarize what you did"""}
]

print("=" * 50)
print("AI Agent ready. Type your task.")
print("Type 'exit' to quit.")
print("=" * 50)

while True:
    user_input = input("\nYou: ")
    if user_input.lower() in ["exit", "quit"]:
        break

    conversation.append({"role": "user", "content": user_input})

    # Initial response
    response = client.chat.completions.create(
        model="qwen",
        messages=conversation,
        stream=True
    )

    reply = ""
    print("\nAgent: ", end="", flush=True)
    for chunk in response:
        delta = chunk.choices[0].delta.content or ""
        print(delta, end="", flush=True)
        reply += delta
    print()

    conversation.append({"role": "assistant", "content": reply})

    # Agentic loop - keeps going until no more tool calls
    while True:
        tool_calls_found = False

        for line in reply.split('\n'):
            line = line.strip()
            if line.startswith('TOOL:'):
                tool_calls_found = True
                try:
                    call = line[5:].strip()
                    tool_name = call.split('(')[0].strip()

                    if tool_name == "write_file":
                        # Robust parsing - get everything after write_file(
                        inner = call[len("write_file")+1:]
                        # Remove trailing )
                        inner = inner[:inner.rfind(')')]
                        result = write_file(inner)

                    elif tool_name in tools:
                        arg = call[len(tool_name)+1:].rstrip(')')
                        result = tools[tool_name](arg)
                    else:
                        result = f"Unknown tool: {tool_name}"

                    print(f"\n[Executing: {tool_name}]")
                    print(f"[Result: {result}]")
                    conversation.append({
                        "role": "user",
                        "content": f"Tool result for {tool_name}: {result}"
                    })
                except Exception as e:
                    print(f"[Tool error: {e}]")

        if not tool_calls_found:
            break

        # Get next response after tools executed
        response = client.chat.completions.create(
            model="qwen",
            messages=conversation,
            stream=True
        )
        reply = ""
        print("\nAgent: ", end="", flush=True)
        for chunk in response:
            delta = chunk.choices[0].delta.content or ""
            print(delta, end="", flush=True)
            reply += delta
        print()
        conversation.append({"role": "assistant", "content": reply})